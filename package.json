{
  "name": "@kud/gandi-cli",
  "version": "0.5.2",
  "description": "A modern CLI for the Gandi v5 REST API",
  "type": "module",
  "bin": {
    "gandi": "./dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.tsx",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "homepage": "https://kud.io/projects/gandi-cli",
  "repository": {
    "type": "git",
    "url": "https://github.com/kud/gandi-cli"
  },
  "license": "MIT",
  "author": {
    "name": "Erwann Mest",
    "url": "https://kud.io"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "gandi",
    "dns",
    "livedns",
    "domains",
    "web-redirect",
    "cli",
    "ink"
  ],
  "dependencies": {
    "commander": "^12.1.0",
    "ink": "^7.0.0",
    "react": "^19.2.5",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.1.1",
    "ink-testing-library": "4.0.0",
    "tsx": "4.21.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9"
  }
}
